# Base path of the Quixam web application.
url: https://<your-quixam-domain>/

# The user to authenticate with (local login name). If not set, the login script will prompt for it.
login: user@example.com

# Path to the file where the authentication token will be stored.
token_file: ./.auth-token

# Your local time zone (https://www.php.net/manual/en/timezones.php)
timezone: Europe/Prague
